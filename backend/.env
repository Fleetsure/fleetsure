# ── Database ───────────────────────────────────────────────────────────────────
# Supabase PostgreSQL — direct connection (port 5432, bypasses pooler)
# Replace [YOUR-DB-PASSWORD] with the password from:
#   Supabase Dashboard → Project Settings → Database → Database password
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.hjtamxpydneuykkcwpfn.supabase.co:5432/postgres

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=FleetSure API
APP_VERSION=1.0.0
DEBUG=true

# ── Auth ───────────────────────────────────────────────────────────────────────
# Legacy key — no longer used for JWT (kept for reference)
SECRET_KEY=change-me-to-a-long-random-secret

# Supabase JWT secret — from Supabase Dashboard → Settings → API → JWT Secret
# Used to verify Supabase-issued JWTs sent from the frontend to Python (pdf/export/billing)
SUPABASE_JWT_SECRET=

# ── Firebase ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=fleetsure-fc010

# ── Parivahan / NAPIX ──────────────────────────────────────────────────────────
# Single key covers both RC (vehicle) and DL (driver licence) lookups.
# Get it free at https://dev.napix.gov.in/nic/parivahan
# Without it: returns realistic demo data (safe fallback).
VAHAN_API_KEY=

# ── Email (signup admin notifications) ────────────────────────────────────────
SMTP_EMAIL=
SMTP_PASSWORD=
ADMIN_EMAIL=fleetsure.internal@gmail.com

# ── Razorpay (billing/subscriptions) ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Supabase API keys (for future Supabase client / Storage / Auth use) ───────
