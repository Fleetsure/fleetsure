# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fleetsure

# App settings
APP_NAME=FleetSure API
APP_VERSION=1.0.0
DEBUG=true

# JWT Secret — change this to a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ── Parivahan / NAPIX ──────────────────────────────────────────────────────────
# FleetSure's single NAPIX key — covers BOTH RC and DL lookups.
# Customers never see or set this. You register once, bake it here, done.
#
# How to get it (free, 1-2 business days):
#   1. Register your organisation at https://dev.napix.gov.in/nic/parivahan
#   2. Apply for "RC Details" product (vehicles)
#   3. Apply for "Sarathi DL" product (driving licences)  ← separate application
#   4. Once approved, both use the SAME key — copy it below
#
# Without this key: lookups return realistic demo/preview data (safe fallback).
# With this key: lookups return real live Parivahan data.
VAHAN_API_KEY=
